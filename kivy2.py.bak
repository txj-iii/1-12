        lit = ""
        if os.path.exists(lit_file):
            with open(lit_file, "r", encoding="utf-8") as f:
                lit = f.read().strip()
                
        detail = view_desc.get(self.selected_view, "")
        
        sel_wl = getattr(self, 'selected_wavelength', 'combined')
        
        target_str = f"Focus on {sel_wl}nm" if sel_wl != "combined" else "Focus on the complete multi-spectral footprint"
        wl_str = f"{sel_wl}nm" if sel_wl != "combined" else "these specific wavelengths"
        
        wl_text = "\n".join([f"- **{wl}**: {desc}" for wl, desc in getattr(self, 'wavelengths', {}).items()])
        if wl_text:
            wl_text = "\n\n### Hyperspectral Wavelength Biomarkers Context:\n" + wl_text
        
        prompt = f"""Act as a senior dermatologist and clinical specialist with expertise in multispectral imaging. Analyze the following preliminary diagnostic result derived from a dermatological screening model:

Diagnosis: {self.diagnosis}
Model Confidence: {self.accuracy}%
Severity Staging: {self.severity}
Current Visual Stream: {self.selected_view.upper()}
Targeted Wavelength: {wl_str}

Please provide a comprehensive professional clinical assessment with emphasis on the specific biophysical characteristics:

## 1. **Multispectral Imaging Analysis** ({target_str})
Based on recent research in hyperspectral and multispectral imaging:
{lit}{wl_text}

## 2. **Clinical Overview with Multispectral Correlation**
Provide a technical explanation of {self.diagnosis} with specific reference to its characteristic spectral signatures at {wl_str}, especially in early stages. Correlate this with the Severity Staging of {self.severity}.

## 3. **Standard of Care** 
Recommended medical interventions, with consideration of how these multispectral structural findings might influence treatment selection and monitoring.

## 4. **Patient Management**
