        # AI CONFIGURATION
        AI_PROVIDER = "dashscope" # Options: "dashscope", "openai"
        
        # To use ChatGPT, set AI_PROVIDER="openai" and paste your Open AI API key below
        OPENAI_API_KEY = "sk-xxxxxxxx" 
        DASHSCOPE_API_KEY = "sk-e6dc062be8a04a37a077d2327c5233ac"
        
        URL = "https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions"
        if AI_PROVIDER == "openai":
            URL = "https://api.openai.com/v1/chat/completions"
        
        API_KEY = OPENAI_API_KEY if AI_PROVIDER == "openai" else DASHSCOPE_API_KEY

        view_desc = {
            "rgb": "Visible clinical surface texture and presentation.",
            "recon": "Deep 31-Band Hyperspectral mapping derived algorithmically from sparse 7-channel hardware inputs to reveal exact morphological patterns.",
            "curve": "A pure continuous theoretical spectral curve overlay (700-1000nm). This confirms the structural shape matches the clinical manifestation of the localized damage.",
            "cockpit": "White-Box Biophysical Pipeline showing decoupled hemodynamics (780nm), Sub-dermal trapped fluid edema (970nm), and underlying lipid barrier disruption (940nm)."
        }
        
        import os
        rag_repo_path = r"c:\Users\User\Downloads\skin\app\rag_repo"
