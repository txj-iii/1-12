## 5. **Follow-up Protocol**
Recommended monitoring schedule, including potential role of multi-modal hyperspectral imaging in tracking treatment response.

**Constraints:**
- Response must be strictly in **English**.
- Maintain a professional, objective, and empathetic medical tone.
- Focus specifically on the {self.selected_view.upper()} visualization and its underlying {wl_str} physics.
- **Critical Disclaimer**: Clearly state this is an AI-assisted analysis based on multispectral imaging literature and not a substitute for in-person biopsy, histopathological examination, or clinical diagnosis by a qualified dermatologist.
- Emphasize that hyperspectral imaging provides complementary data but requires clinical correlation."""

        try:
            print(f"\n[AI DEBUG] ====================")
            print(f"[AI DEBUG] PROMPT SENT TO {AI_PROVIDER.upper()}:")
            print(f"[AI DEBUG] {prompt}")
            print(f"[AI DEBUG] ====================")
            
            payload = {
                "model": "qwen-max" if AI_PROVIDER == "dashscope" else "gpt-4-turbo", 
                "messages": [{"role": "system", "content": "You are a Medical Physicist & Expert Dermatologist."}, {"role": "user", "content": prompt}], 
                "max_tokens": 1200
            }
            res = requests.post(URL, headers={"Authorization": f"Bearer {API_KEY}"}, json=payload, timeout=120)
            
            print(f"[AI DEBUG] HTTP STATUS: {res.status_code}")
            print(f"[AI DEBUG] RESPONSE DATA: {res.text}")
            print(f"[AI DEBUG] ====================\n")
            
            if res.status_code == 200: return res.json()['choices'][0]['message']['content']
            else: return f"API Error {res.status_code}: {res.text}"
        except requests.exceptions.Timeout:
            return "Connection Error: AI generation timed out after 120s. \n\n*Note: The RAG literature is NOT downloading from the internet; it is mapped locally. The delay occurs strictly because DashScope's Qwen model is analyzing complex physics. Open kivy2.py and set AI_PROVIDER='openai' to use ChatGPT.*"
        except Exception as e: return f"Connection Error: {e}"

    def show_result(self, text):
        self.btn_analysis.disabled = False
        self.btn_analysis.text = "ANALYSIS"
        App.get_running_app().analysis_screen.update_report(self.diagnosis, self.accuracy, self.selected_view.upper(), md_to_bbcode(text))
        App.get_running_app().screen_manager.current = 'analysis'

class AnalysisScreen(Screen):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.layout = BoxLayout(orientation='vertical', padding=dp(25), spacing=dp(20))
        box = BoxLayout(size_hint=(1, None), height=dp(60))
        box.add_widget(Label(text='Biophysical Report', color=THEME['text'], font_size='28sp', font_name='Times New Roman', bold=True, halign='left', valign='middle'))
        self.layout.add_widget(box)

        card = Card(orientation='vertical', padding=dp(20), size_hint=(1, 1))
        scroll = ScrollView(size_hint=(1, 1), bar_width=dp(5))
        self.report_label = Label(text='Wait...', size_hint_y=None, color=THEME['text'], font_size='18sp', font_name='Times New Roman', line_height=1.5, halign='left', valign='top', markup=True)
        self.report_label.bind(width=lambda *x: self.report_label.setter('text_size')(self.report_label, (self.report_label.width, None)))
        self.report_label.bind(texture_size=lambda *x: self.report_label.setter('height')(self.report_label, self.report_label.texture_size[1]))
        scroll.add_widget(self.report_label)
        card.add_widget(scroll)
        self.layout.add_widget(card)

        btn_box = BoxLayout(size_hint=(1, None), height=dp(70), spacing=dp(20))
        back_btn = Button(text='< BACK TO CONSOLE', background_color=(0, 0, 0, 0), color=THEME['primary'], font_size='18sp', font_name='Times New Roman', bold=True)
        def update_back(inst, val):
            inst.canvas.before.clear()
            with inst.canvas.before:
                Color(1, 1, 1, 0.05)
                RoundedRectangle(pos=inst.pos, size=inst.size, radius=[dp(8)])
        back_btn.bind(pos=update_back, size=update_back)
        back_btn.bind(on_press=self.go_back)
        btn_box.add_widget(back_btn)
        self.layout.add_widget(btn_box)
        self.add_widget(self.layout)

    def update_report(self, diagnosis, accuracy, mode, text):
        full_text = f"[b]CLINICAL DIAGNOSIS:[/b] {diagnosis} ([color=2DD4BF]{accuracy}%[/color] Confidence)\n"
        full_text += f"[b]BIOPHYSICAL SEVERITY:[/b] [color=F87171]{getattr(App.get_running_app().dashboard_screen, 'severity', 'Unknown')}[/color]\n"
        full_text += f"[b]ANALYTICAL BACKBONE:[/b] [color=34D399]{mode}[/color] Multi-modal View\n"
        full_text += "-"*50 + "\n\n" + text
        self.report_label.text = full_text
        for child in self.children[0].children:
            if isinstance(child, Card): child.children[0].scroll_y = 1

    def go_back(self, instance): App.get_running_app().screen_manager.current = 'dashboard'

class MedicalApp(App):
    def build(self):
        self.title = 'DermaSpectra Application'
        self.screen_manager = ScreenManager(transition=FadeTransition())
        self.dashboard_screen = DashboardScreen(name='dashboard')
        self.analysis_screen = AnalysisScreen(name='analysis')
        self.screen_manager.add_widget(self.dashboard_screen)
        self.screen_manager.add_widget(self.analysis_screen)
        return self.screen_manager

if __name__ == '__main__':
    MedicalApp().run()
